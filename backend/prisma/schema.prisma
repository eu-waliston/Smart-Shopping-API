generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  shoppingLists ShoppingList[]
}

model ShoppingList {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items ShoppingItem[]
}

model ShoppingItem {
  id       String  @id @default(uuid())
  name     String
  quantity Int
  checked  Boolean @default(false)
  category String?

  createdAt DateTime @default(now())

  listId String
  list   ShoppingList @relation(fields: [listId], references: [id])
}

model Market {
  id      String @id @default(uuid())
  name    String
  city    String
  address String

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())

  promotions Promotion[]
}

model Promotion {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String?
  price       Float
  imageUrl    String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
}
